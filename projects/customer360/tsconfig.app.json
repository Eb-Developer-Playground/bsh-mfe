    "src/app/shared/components/dialog/**/*.ts",
    "src/app/shared/components/pdf-dialog/**/*.ts",
    "src/app/shared/components/verify-skip-bio/**/*.ts",
    "src/app/shared/components/change-of-signature/**/*.ts",
    "src/app/home/customer/account-statements/account-statements.module.ts",
    "src/app/home/customer/account-statements/account-statements-routing.module.ts",
    "src/app/home/customer/save-and-invest/material.module.ts",
