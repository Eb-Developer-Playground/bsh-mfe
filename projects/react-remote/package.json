{
  "name": "react-remote",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "tailwind:build": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind.generated.css --minify",
    "tailwind:watch": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind.generated.css --watch",
    "dev": "pnpm run tailwind:build && concurrently --kill-others --names tailwind,vite \"pnpm run tailwind:watch\" \"vite --host 0.0.0.0 --port 4205 --strictPort\"",
    "build": "pnpm run tailwind:build && tsc -b && vite build",
    "build:federation": "pnpm run tailwind:build && node scripts/build-federation.mjs",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0 --port 4204 --strictPort",
    "preview:federation": "vite preview --host 0.0.0.0 --port 4204 --strictPort --outDir dist",
    "serve:federation": "pnpm run build:federation && pnpm run preview:federation"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@softarc/native-federation": "4.3.1",
    "@softarc/native-federation-esbuild": "4.0.0",
    "@tailwindcss/cli": "^4.3.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
