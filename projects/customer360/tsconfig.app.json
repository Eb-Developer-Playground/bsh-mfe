      "@env/*": ["src/environments/*"],
      "@assets/*": ["src/assets/*"],
      "@shared/*": ["src/app/shared/*"]
    },
    "types": []
  },
  "include": ["src/**/*.ts", "../equity-auth/src/public-api.ts"],
  "exclude": [
