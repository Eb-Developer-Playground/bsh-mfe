{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": [],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "equity-auth": [
        "../../projects/equity-auth/src/public-api.ts"
      ],
      "@app/*": [
        "src/app/*"
      ],
      "@shared/*": [
        "src/app/shared/*"
      ],
      "@env/*": [
        "src/environments/*"
      ],
      "@assets/*": [
        "src/assets/*"
      ],
      "src/app/*": [
        "src/app/*"
      ],
      "@angular/flex-layout": [
        "src/app/shared/flex-layout-stubs/index.ts"
      ],
      "@angular/flex-layout/flex": [
        "src/app/shared/flex-layout-stubs/flex.ts"
      ],
      "@angular/flex-layout/extended": [
        "src/app/shared/flex-layout-stubs/extended.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "../equity-auth/src/public-api.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
